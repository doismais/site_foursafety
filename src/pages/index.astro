---
// index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CtaAtuacao from '../components/CtaAtuacao.astro';
import Numeros from '../components/Numeros.astro';
import Produtos from '../components/Produtos.astro';
import Cenarios from '../components/Cenarios.astro';
import BannerTubos from '../components/BannerTubos.astro';
---

<Layout title="4Safety — Soluções Técnicas em Segurança do Trabalho" description="Soluções técnicas para segurança ocupacional com foco em ambientes críticos, documentação sob consulta e marcas globais.">
  <main>
    <Hero />
    <BannerTubos />
    <CtaAtuacao />
    <Numeros />
    <Produtos />
    <Cenarios />
  </main>
  
  <!-- Global Cart Script -->
  <script src="/js/cart.js" is:inline></script>
</Layout>
