---
import Layout from '../../layouts/Layout.astro';
import '../../styles/products.css';
---

<Layout title="Capacete Focus B | 4Safety" description="Indicado para trabalhos com energia elétrica, resgate e alpinismo. ABS com tratamento UV.">
  
  <main class="product-hero">
    <div style="max-width: 1240px; margin: 0 auto 2rem; position: relative; z-index: 10;">
      <a href="/produtos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--g700); text-decoration: none; font-weight: 600; font-family: var(--font-body); font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--g700)'"><span style="font-size: 1.2rem;">&larr;</span> Voltar para Produtos</a>
    </div>
    <div class="product-grid">
      <div class="product-gallery reveal">
        <img src="/images/products/capacete_focus_a/capacete_focus_a2.webp" alt="Capacete Focus B" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 10px;" loading="lazy" />
      </div>
      <div class="product-info reveal">
        <div class="product-tag">CA 17.098</div>
        <h1 class="product-title">Capacete Focus B</h1>
        <p class="product-description" style="margin-bottom: 1.5rem;">O Capacete Focus B é indicado para trabalhos com energia elétrica e também para atividades como escalada, resgate, alpinismo e espeleologia. Fabricado em ABS com tratamento UV.</p>
        
        <div class="product-details-inline" style="background: rgba(255, 255, 255, 0.5); padding: 1.25rem; border-radius: 12px; border: 1px solid rgba(28, 25, 22, 0.08); margin-bottom: 1.5rem;">
          <p class="product-section-kicker" style="font-size: 0.6rem; color: var(--orange); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.3rem; font-family: var(--font-mono); font-weight: 600;">Ficha rápida</p>
          <h2 class="specs-title" style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.8rem; font-family: var(--font-display);">Detalhes do Produto</h2>
          <div style="font-size: 0.85rem; line-height: 1.6; color: var(--g700);">
            <p class="product-section-sub">O Capacete Focus B é indicado para trabalhos com energia elétrica e também para atividades como escalada, resgate, alpinismo e espeleologia. Fabricado em ABS com tratamento UV, é leve, confortável e conta com fitas antialérgicas, testeira acolchoada, suporte para lanterna e encaixes para viseira, protetor auricular e protetor de nuca.</p>
            <p class="product-section-sub" style="margin-top: 1rem;">Possui CA nº 17.098, atende à Norma NBR 8221:2019 e tem certificação válida até 16/07/2028.</p>
          </div>
        </div>

        <div class="product-meta" style="margin-bottom: 1rem;">
          <span class="meta-badge">Capacetes</span>
          <span class="meta-badge">Disponibilidade: Sob consulta</span>
        </div>
        <div class="product-actions">
          <button class="btn-add-cart btn-primary" data-cart-add data-product-name="Capacete Focus B" data-product-img="/images/products/capacete_focus_a/capacete_focus_a2.webp" data-product-slug="capacete-focus-b" style="width: 100%;">
             Solicitar mais informações
          </button>
        </div>
      </div>
    </div>
  </main>

  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js" defer></script>

  <!-- Script de Reveal -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
          el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 580, delay: stagger, fill: "forwards", easing: "cubic-bezier(0.22,1,0.36,1)" });
          observer.unobserve(el);
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
      
      reveals.forEach(el => observer.observe(el));
    });
  </script>

</Layout>
