---
import Layout from '../../layouts/Layout.astro';
import '../../styles/products.css';
---

<Layout title="Equipamentos para Altura | 4Safety — Especialistas em Segurança" description="Cinturões paraquedistas e dispositivos trava-quedasselecionados conforme risco e documentação do modelo indicado.">
  
  <main class="product-hero">
    <div style="max-width: 1240px; margin: 0 auto 2rem; position: relative; z-index: 10;">
      <a href="/produtos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--g700); text-decoration: none; font-weight: 600; font-family: var(--font-body); font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--g700)'"><span style="font-size: 1.2rem;">&larr;</span> Voltar para Produtos</a>
    </div>
    <div class="product-grid">
      <div class="product-gallery-wrapper reveal">
        <div class="product-gallery">
          <img id="main-product-image" src="/images/products/produto-equipamentos-altura.webp" alt="Equipamentos para Altura" />
        </div>
        <div class="product-thumbnails">
          <button class="thumb-btn active" data-src="/images/products/produto-equipamentos-altura.webp" aria-label="Ver imagem 1">
            <img src="/images/products/produto-equipamentos-altura.webp" alt="Miniatura Altura" />
          </button>
          <button class="thumb-btn" data-src="/images/products/cinturoes/cinturoes.webp" aria-label="Ver imagem 2">
            <img src="/images/products/cinturoes/cinturoes.webp" alt="Miniatura Cinturões" />
          </button>
          <button class="thumb-btn" data-src="/images/products/talabartes.webp" aria-label="Ver imagem 3">
            <img src="/images/products/talabartes.webp" alt="Miniatura Talabartes" />
          </button>
          <button class="thumb-btn" data-src="/images/products/trava-quedas.webp" aria-label="Ver imagem 4">
            <img src="/images/products/trava-quedas.webp" alt="Miniatura Trava-Quedas" />
          </button>
        </div>
      </div>
      <div class="product-info reveal">
        <div class="product-tag">Trabalho em Altura — NR-35</div>
        <h1 class="product-title">Equipamentos para Altura</h1>
        <p class="product-description" style="margin-bottom: 1rem;">A linha de Trabalho em Altura da 4Safety reúne cinturões, talabartes, trava-quedas e acessórios de segurança para operações que exigem proteção, mobilidade e confiança em campo.</p>
        <p class="product-description" style="margin-bottom: 1rem;">São equipamentos desenvolvidos para diferentes aplicações, como retenção de queda, posicionamento, movimentação e acesso em altura, atendendo às necessidades de profissionais que atuam em estruturas, plataformas, andaimes, cestos aéreos, linhas de vida e ambientes industriais.</p>
        <p class="product-description" style="margin-bottom: 1.5rem;">Soluções completas para tornar sua operação mais segura, técnica e adequada ao cenário de trabalho.</p>
        <div class="product-meta">
          <span class="meta-badge">NR-35</span>
          <span class="meta-badge">Segurança Ativa</span>
          <span class="meta-badge">Certificado</span>
        </div>
        <div class="product-actions">
          <button class="btn-add-cart btn-primary" data-cart-add data-product-name="Equipamentos para Altura" data-product-img="/images/products/produto-equipamentos-altura.webp">
             Solicitar mais informações
          </button>
        </div>
      </div>
    </div>

    <!-- Specs Section -->
    <section class="product-specs">
      <div class="section-inner product-sections-stack">

        <div class="product-section-block">
          <div class="product-section-head reveal">
            <p class="product-section-kicker">Sugestões de produtos</p>
            <h2 class="specs-title">Veja mais produtos</h2>
            <p class="product-section-sub">Itens que normalmente entram junto na mesma operação ou complementam a especificação técnica.</p>
          </div>
          <div class="related-grid">
            <a class="related-card" href="/produtos/calcados">
              <div class="related-card-media">
                <img src="/images/products/produto-botas-calzados.webp" alt="Botas e Calçados" />
              </div>
              <div class="related-card-copy">
                <span class="related-card-tag">Proteção dos Pés — NR-6</span>
                <h3>Botas e Calçados</h3>
                <p>Botinas e sapatos de segurança para proteção contra impactos, quedas e agentes agressivos.</p>
              </div>
            </a>
            <a class="related-card" href="/produtos/respiratorio">
              <div class="related-card-media">
                <img src="/images/products/produto-protecao-respiratoria.webp" alt="Proteção Respiratória" />
              </div>
              <div class="related-card-copy">
                <span class="related-card-tag">Segurança Pulmonar — NR-6</span>
                <h3>Proteção Respiratória</h3>
                <p>Representamos alguns tipos de máscaras respiratórias.A disponibilidade e a indicação da linha ideal são confirmadas sobconsulta técnica.</p>
              </div>
            </a>
            <a class="related-card" href="/produtos/deteccao-de-gas/detector-portatil">
              <div class="related-card-media">
                <img src="/images/products/produto-detector-gas-portatil.webp" alt="Detector de Gás Portátil" />
              </div>
              <div class="related-card-copy">
                <span class="related-card-tag">Monitoramento Contínuo — NR-33</span>
                <h3>Detector de Gás Portátil</h3>
                <p>Detector multigás para monitoramento simultâneo de O2, CO, H2S e gases combustíveis (LEL).</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js"></script>

  <!-- Script de Reveal & Galeria -->
  <script>
    document.addEventListener('astro:page-load', () => {
      // Reveal animations
      const reveals = document.querySelectorAll(".reveal");
      if (reveals.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el = entry.target;
            const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
            el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
              { duration: 580, delay: stagger, fill: "forwards", easing: "cubic-bezier(0.22,1,0.36,1)" });
            observer.unobserve(el);
          });
        }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
        
        reveals.forEach(el => observer.observe(el));
      }

      // Thumbnail gallery logic
      const mainImg = document.getElementById('main-product-image');
      const thumbs = document.querySelectorAll('.thumb-btn');
      if (mainImg && thumbs.length > 0) {
        thumbs.forEach(btn => {
          btn.addEventListener('click', () => {
            const src = btn.getAttribute('data-src');
            if (src) {
              mainImg.setAttribute('src', src);
            }
            thumbs.forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
          });
        });
      }
    });
  </script>

</Layout>
