---
import Layout from '../../layouts/Layout.astro';
import '../../styles/products.css';
---

<Layout title="Máscaras e Respiradores de Proteção | 4Safety" description="Linha completa de máscaras e respiradores descartáveis e reutilizáveis, PFF2, semifaciais e faciais inteiras.">
  
  <main class="product-hero">
    <div style="max-width: 1240px; margin: 0 auto 2rem; position: relative; z-index: 10;">
      <a href="/produtos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--g700); text-decoration: none; font-weight: 600; font-family: var(--font-body); font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--g700)'"><span style="font-size: 1.2rem;">&larr;</span> Voltar para Produtos</a>
    </div>
    <div class="product-grid">
      <div class="product-gallery reveal">
        <div class="carousel-container">
          <div class="carousel-wrapper" id="carousel-mascaras-respiradores">
            <img src="/images/products/mascaras_respiradores/8.webp" alt="Máscaras e Respiradores de Proteção" class="carousel-slide" />
          <img src="/images/products/mascaras_respiradores/9.webp" alt="Máscaras e Respiradores de Proteção" class="carousel-slide" />
          <img src="/images/products/mascaras_respiradores/10.webp" alt="Máscaras e Respiradores de Proteção" class="carousel-slide" />
          </div>
          <button class="carousel-btn prev-btn" data-target="carousel-mascaras-respiradores">❮</button>
          <button class="carousel-btn next-btn" data-target="carousel-mascaras-respiradores">❯</button>
        </div>
      </div>
      <div class="product-info reveal">
        <div class="product-tag">Respiratória</div>
        <h1 class="product-title">Máscaras e Respiradores de Proteção</h1>
        <p class="product-description" style="margin-bottom: 1.5rem;">Linha completa de máscaras e respiradores descartáveis e reutilizáveis, PFF2, semifaciais e faciais inteiras.</p>
        
        <div class="product-details-inline" style="background: rgba(255, 255, 255, 0.5); padding: 1.25rem; border-radius: 12px; border: 1px solid rgba(28, 25, 22, 0.08); margin-bottom: 1.5rem;">
          <p class="product-section-kicker" style="font-size: 0.6rem; color: var(--orange); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.3rem; font-family: var(--font-mono); font-weight: 600;">Ficha rápida</p>
          <h2 class="specs-title" style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.8rem; font-family: var(--font-display);">Detalhes do Produto</h2>
          <div style="font-size: 0.85rem; line-height: 1.6; color: var(--g700);">
            <p class="product-section-sub">A 4Safety oferece uma linha completa de máscaras e respiradores descartáveis e reutilizáveis, desenvolvidos com alta tecnologia, conforto e excelente vedação para máxima segurança respiratória.</p><p class="product-section-sub" style="margin-top: 1rem;">Disponibilizamos modelos PFF2 com e sem válvula, respiradores semifaciais, máscaras faciais inteiras e equipamentos de fuga, atendendo às mais diversas necessidades industriais. Nossos produtos se destacam pelo design ergonômico, qualidade dos materiais e comprovada performance, garantindo maior produtividade e proteção aos profissionais.</p><p class="product-section-sub" style="margin-top: 1rem;">Soluções confiáveis para quem precisa respirar com segurança em qualquer ambiente.</p>
          </div>
        </div>

        <div class="product-meta" style="margin-bottom: 1rem;">
          <span class="meta-badge">Respiratória</span>
          <span class="meta-badge">Disponibilidade: Sob consulta</span>
        </div>
        <div class="product-actions">
          <button class="btn-add-cart btn-primary" data-cart-add data-product-name="Máscaras e Respiradores de Proteção" data-product-img="/images/products/mascaras_respiradores/8.webp" data-product-slug="mascaras-respiradores" style="width: 100%;">
             Adicionar ao Orçamento
          </button>
        </div>
      </div>
    </div>
  </main>

  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js"></script>

  <!-- Script de Reveal & Carousel -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
          el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 580, delay: stagger, fill: "forwards", easing: "cubic-bezier(0.22,1,0.36,1)" });
          observer.unobserve(el);
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
      
      reveals.forEach(el => observer.observe(el));

      // Carousel logic
      const prevBtns = document.querySelectorAll('.prev-btn');
      const nextBtns = document.querySelectorAll('.next-btn');
      
      prevBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (targetId) {
            const c = document.getElementById(targetId);
            if(c) c.scrollBy({ left: -c.clientWidth, behavior: 'smooth' });
          }
        });
      });
      
      nextBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (targetId) {
            const c = document.getElementById(targetId);
            if(c) c.scrollBy({ left: c.clientWidth, behavior: 'smooth' });
          }
        });
      });
    });
  </script>

  <style>
  .carousel-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 10px;
  }
  .carousel-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    height: 100%;
    scrollbar-width: none;
  }
  .carousel-wrapper::-webkit-scrollbar {
    display: none;
  }
  .carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    object-fit: cover;
  }
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.8);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    z-index: 10;
    transition: background 0.3s, color 0.3s;
  }
  .carousel-btn.prev-btn {
    left: 10px;
  }
  .carousel-btn.next-btn {
    right: 10px;
  }
</style>

</Layout>
