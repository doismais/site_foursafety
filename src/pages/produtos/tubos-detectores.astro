---
import Layout from '../../layouts/Layout.astro';
import '../../styles/products.css';
---

<Layout title="Tubos Detectores | 4Safety" description="Ideais para medições rápidas e específicas em campo.">
  
  <main class="product-hero">
    <div style="max-width: 1240px; margin: 0 auto 2rem; position: relative; z-index: 10;">
      <a href="/produtos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--g700); text-decoration: none; font-weight: 600; font-family: var(--font-body); font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--g700)'"><span style="font-size: 1.2rem;">&larr;</span> Voltar para Produtos</a>
    </div>
    <div class="product-grid">
      <div class="product-gallery reveal" style="position: relative;">
        <div id="gallery-slider" style="display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; -ms-overflow-style: none; scrollbar-width: none; border-radius: 10px;">
          <img src="/images/products/tubos_colorimetricos/Uniphos-Tubes-1.jpg" alt="Tubo Detector Uniphos" style="flex: 0 0 100%; width: 100%; aspect-ratio: 4/3; object-fit: cover; scroll-snap-align: start;" />
          <img src="/images/products/tubos_colorimetricos/Uniphos-Tubes-2.jpg" alt="Tubo Detector Uniphos 2" style="flex: 0 0 100%; width: 100%; aspect-ratio: 4/3; object-fit: cover; scroll-snap-align: start;" />
          <img src="/images/products/tubos_colorimetricos/Uniphos-Tubes-3.jpg" alt="Tubo Detector Uniphos 3" style="flex: 0 0 100%; width: 100%; aspect-ratio: 4/3; object-fit: cover; scroll-snap-align: start;" />
          <img src="/images/products/tubos_colorimetricos/Uniphos-Tubes-4.jpg" alt="Tubo Detector Uniphos 4" style="flex: 0 0 100%; width: 100%; aspect-ratio: 4/3; object-fit: cover; scroll-snap-align: start;" />
          <img src="/images/products/tubos_colorimetricos/Uniphos-Tubes-5.jpg" alt="Tubo Detector Uniphos 5" style="flex: 0 0 100%; width: 100%; aspect-ratio: 4/3; object-fit: cover; scroll-snap-align: start;" />
        </div>
        <button class="prev-btn" data-target="gallery-slider" style="position: absolute; top: 50%; left: 10px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); z-index: 10;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="next-btn" data-target="gallery-slider" style="position: absolute; top: 50%; right: 10px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); z-index: 10;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
      <div class="product-info reveal">
        <div class="product-tag">Segurança</div>
        <h1 class="product-title">Tubos Detectores</h1>
        <p class="product-description" style="margin-bottom: 1.5rem;">Ideais para medições rápidas e específicas em campo.</p>
        
        <div class="product-details-inline" style="background: rgba(255, 255, 255, 0.5); padding: 1.25rem; border-radius: 12px; border: 1px solid rgba(28, 25, 22, 0.08); margin-bottom: 1.5rem;">
          <p class="product-section-kicker" style="font-size: 0.6rem; color: var(--orange); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.3rem; font-family: var(--font-mono); font-weight: 600;">Ficha rápida</p>
          <h2 class="specs-title" style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.8rem; font-family: var(--font-display);">Detalhes do Produto</h2>
          <div style="font-size: 0.85rem; line-height: 1.6; color: var(--g700);">
            <p class="product-section-sub">Os tubos detectores Uniphos são utilizados com a bomba manual (ASP 40) para detecção localizada e medição em campo e espaços confinados de diversos tipos de gases e vapores.</p>
            
            <h3 style="font-size: 0.95rem; font-weight: 700; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--black);">Aplicações:</h3>
            <ul style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Espaços confinados (Silos, armazéns, tanques)</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Controle de processo</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Prevenção de acidentes</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Análise da chaminé</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Determinação da pureza do gás medicinal</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Análises de laboratório</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Qualidade do ar em ambiente externo</li>
            </ul>

            <h3 style="font-size: 0.95rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--black);">Características:</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Alta precisão e sensibilidade</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Escalas de medidas fáceis de ler</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Tecnologia de tubo fino</li>
              <li style="display: flex; align-items: flex-start; gap: 0.4rem;"><span style="color: var(--orange); font-weight: bold;">&bull;</span> Compatível com bombas de outros fabricantes</li>
            </ul>
          </div>
        </div>

        <div class="product-meta" style="margin-bottom: 1rem;">
          <span class="meta-badge">Segurança</span>
          <span class="meta-badge">Disponibilidade: Sob consulta</span>
        </div>
        <div class="product-actions">
          <button class="btn-add-cart btn-primary" data-cart-add data-product-name="Tubos Detectores" data-product-img="/images/products/detectores_gas/1.webp" data-product-slug="tubos-detectores" style="width: 100%;">
             Solicitar mais informações
          </button>
        </div>
      </div>
    </div>
  </main>

  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js"></script>

  <!-- Script de Reveal & Carousel -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
          el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 580, delay: stagger, fill: "forwards", easing: "cubic-bezier(0.22,1,0.36,1)" });
          observer.unobserve(el);
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
      
      reveals.forEach(el => observer.observe(el));

      // Carousel logic
      const prevBtns = document.querySelectorAll('.prev-btn');
      const nextBtns = document.querySelectorAll('.next-btn');
      
      prevBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (targetId) {
            const c = document.getElementById(targetId);
            if(c) c.scrollBy({ left: -c.clientWidth, behavior: 'smooth' });
          }
        });
      });
      
      nextBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (targetId) {
            const c = document.getElementById(targetId);
            if(c) c.scrollBy({ left: c.clientWidth, behavior: 'smooth' });
          }
        });
      });
    });
  </script>

  

</Layout>
