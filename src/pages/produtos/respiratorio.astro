---
import Layout from '../../layouts/Layout.astro';
import '../../styles/products.css';
---

<Layout title="Proteção Respiratória | 4Safety — Especialistas em Segurança" description="Representamos alguns tipos de máscaras respiratórias.A disponibilidade e a indicação da linha ideal são confirmadas sobconsulta técnica.">
  
  <main class="product-hero">
    <div style="max-width: 1240px; margin: 0 auto 2rem; position: relative; z-index: 10;">
      <a href="/produtos" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--g700); text-decoration: none; font-weight: 600; font-family: var(--font-body); font-size: 0.95rem; transition: color 0.2s;" onmouseover="this.style.color='var(--orange)'" onmouseout="this.style.color='var(--g700)'"><span style="font-size: 1.2rem;">&larr;</span> Voltar para Produtos</a>
    </div>
    <div class="product-grid">
      <div class="product-gallery reveal">
        <img src="/images/products/produto-protecao-respiratoria.webp" alt="Proteção Respiratória" />
      </div>
      <div class="product-info reveal">
        <div class="product-tag">Segurança Pulmonar — NR-6</div>
        <h1 class="product-title">Proteção Respiratória</h1>
        <p class="product-description">Representamos alguns tipos de máscaras respiratórias.A disponibilidade e a indicação da linha ideal são confirmadas sobconsulta técnica.</p>
        <div class="product-meta">
          <span class="meta-badge">NR-6</span>
          <span class="meta-badge">Filtros Avançados</span>
          <span class="meta-badge">Conforto</span>
        </div>
        <div class="product-actions">
          <button class="btn-add-cart btn-primary" data-cart-add data-product-name="Proteção Respiratória" data-product-img="/images/products/produto-protecao-respiratoria.webp">
             Solicitar mais informações
          </button>
        </div>
      </div>
    </div>

    <!-- Specs Section -->
    <section class="product-specs">
      <div class="section-inner product-sections-stack">
        <div class="product-section-block">
          <div class="product-section-head reveal">
            <p class="product-section-kicker">Ficha rápida</p>
            <h2 class="specs-title">Especificações Técnicas</h2>
            <p class="product-section-sub">Tudo o que a equipe precisa conferir antes de fechar aplicação, norma e compra.</p>
          </div>
          <div class="specs-card">
            <div class="specs-list">
              <div class="spec-row">
                <span class="spec-label">Tipo</span>
                <span class="spec-value">Máscaras Semi-Faciais / Faciais Inteiras</span>
              </div>
              <div class="spec-row">
                <span class="spec-label">Filtros</span>
                <span class="spec-value">Gases, Vapores, Particulados</span>
              </div>
              <div class="spec-row">
                <span class="spec-label">Material</span>
                <span class="spec-value">Silicone / Elastômero</span>
              </div>
              <div class="spec-row">
                <span class="spec-label">Normas</span>
                <span class="spec-value">ABNT NBR 13694 / 13695</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="product-section-block">
          <div class="product-section-head reveal">
            <p class="product-section-kicker">Sugestões de produtos</p>
            <h2 class="specs-title">Veja mais produtos</h2>
            <p class="product-section-sub">Itens que normalmente entram junto na mesma operação ou complementam a especificação técnica.</p>
          </div>
          <div class="related-grid">
            <a class="related-card" href="/produtos/deteccao-de-gas/tubo-colorimetrico">
              <div class="related-card-media">
                <img src="/images/products/produto-tubo-colorimetrico-uniphos.webp" alt="Tubo Colorimétrico Uniphos" />
              </div>
              <div class="related-card-copy">
                <span class="related-card-tag">Detecção de Gás — NR-33</span>
                <h3>Tubo Colorimétrico Uniphos</h3>
                <p>Solução de alta precisão para análise quantitativa de gases em campo. Ideal para ambientes industriais e espaços confinados.</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js"></script>

  <!-- Script de Reveal -->
  <script>
  document.addEventListener('astro:page-load', () => {
    const prevBtns = document.querySelectorAll('.prev-btn');
    const nextBtns = document.querySelectorAll('.next-btn');
    
    prevBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (targetId) {
          const c = document.getElementById(targetId);
          if(c) c.scrollBy({ left: -c.clientWidth, behavior: 'smooth' });
        }
      });
    });
    
    nextBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (targetId) {
          const c = document.getElementById(targetId);
          if(c) c.scrollBy({ left: c.clientWidth, behavior: 'smooth' });
        }
      });
    });
  });
</script>

</Layout>
