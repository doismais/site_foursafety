---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Página Não Encontrada | 4Safety" description="A página que você procura não existe ou foi movida. Volte para a página inicial ou explore nossos produtos.">
  <main class="error-page">
    <div class="error-content reveal">
      <span class="error-code">404</span>
      <h1 class="error-title">Ambiente Não Encontrado</h1>
      <p class="error-description">
        A página que você está tentando acessar não existe ou foi movida. 
        Certifique-se de que a rota está correta ou explore nosso catálogo.
      </p>
      <div class="error-actions">
        <a href="/" class="btn-primary">Voltar para o Início</a>
        <a href="/produtos" class="btn-secondary">Ver Produtos</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Esconder o cabeçalho apenas nesta página */
  :global(header) {
    display: none !important;
  }

  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70svh;
    padding: 5rem var(--container-px);
    text-align: center;
    background: #0f0d0b;
  }
  
  .error-content {
    max-width: 600px;
    width: 100%;
  }
  
  .error-code {
    font-family: var(--font-mono);
    font-size: 6rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
  }
  
  .error-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--white);
  }
  
  .error-description {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2.5rem;
    font-size: 1rem;
    line-height: 1.6;
  }
  
  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }
  
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background: var(--orange);
    color: var(--white);
    box-shadow: 0 10px 26px rgba(255, 0, 0, 0.2);
    border: 1px solid transparent;
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(255, 0, 0, 0.3);
  }
  
  .btn-secondary {
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: transparent;
  }
  
  .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }
  
  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      margin: 0 auto;
    }
    .btn-primary,
    .btn-secondary {
      width: 100%;
    }
    .error-code {
      font-size: 4.5rem;
    }
    .error-title {
      font-size: 1.8rem;
    }
  }
</style>
