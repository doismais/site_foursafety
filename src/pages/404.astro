---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Página Não Encontrada | 4Safety" description="A página que você procura não existe ou foi movida. Volte para a página inicial ou explore nossos produtos.">
  <main class="error-page">
    <div class="error-content reveal">
      <span class="error-code">404</span>
      <h1 class="error-title">Ambiente Não Encontrado</h1>
      <p class="error-description">
        A página que você está tentando acessar não existe ou foi movida. 
        Certifique-se de que a rota está correta ou explore nosso catálogo.
      </p>
      <div class="error-actions">
        <a href="/" class="btn-primary">Voltar para o Início</a>
        <a href="/produtos" class="btn-secondary">Ver Produtos</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    padding: var(--spacing-xl) var(--spacing-md);
    text-align: center;
  }
  
  .error-content {
    max-width: 600px;
  }
  
  .error-code {
    font-family: var(--font-mono);
    font-size: 5rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  
  .error-title {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }
  
  .error-description {
    color: var(--color-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }
  
  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  
  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
    }
  }
</style>
