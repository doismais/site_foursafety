  <!-- Script do Carrinho -->
  <script is:inline src="/js/cart.js" defer></script>

  <!-- Script de Filtro e Reveal -->
  <script>
    document.addEventListener('astro:page-load', () => {
      // Filter logic
      const filterBtns = document.querySelectorAll(".filter-btn");
      const filterSelect = document.getElementById("catalog-filter-select");
      const cards = document.querySelectorAll(".produto-card");
      const resultsEl = document.getElementById("catalog-results");

      function applyFilter(f: string) {
        filterBtns.forEach(b => b.classList.remove("active"));
        const activeBtn = document.querySelector(`.filter-btn[data-filter="${f}"]`);
        if (activeBtn) activeBtn.classList.add("active");
        if (filterSelect) (filterSelect as HTMLSelectElement).value = f;

        let count = 0;
        cards.forEach(card => {
          const htmlCard = card as HTMLElement;
          const categories = (htmlCard.dataset.cat || "").split(/\s+/);
          const show = f === "all" || categories.includes(f);
          if (show) {
            htmlCard.style.display = "flex";
              htmlCard.animate([{ opacity: 0, transform: "scale(.96)" }, { opacity: 1, transform: "scale(1)" }],
              { duration: 280, fill: "forwards" as FillMode, easing: "ease-out" });
            count++;
          } else {
            htmlCard.style.display = "none";
          }
        });
        if (resultsEl) resultsEl.textContent = `${count} produto${count !== 1 ? "s" : ""} encontrado${count !== 1 ? "s" : ""}`;
      }

      filterBtns.forEach(btn => btn.addEventListener("click", () => applyFilter((btn as HTMLElement).dataset.filter || "all")));
      if (filterSelect) filterSelect.addEventListener("change", () => applyFilter((filterSelect as HTMLSelectElement).value));
      
      // Check URL parameters for initial filter
      const urlParams = new URLSearchParams(window.location.search);
      const initialFilter = urlParams.get('filter') || "all";
      applyFilter(initialFilter);

      // Reveal
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
          el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 580, delay: stagger, fill: "forwards" as FillMode, easing: "cubic-bezier(0.22,1,0.36,1)" });
          observer.unobserve(el);
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
      
      reveals.forEach(el => observer.observe(el));
    });
  </script>

</Layout>

<style>
  /* Estilos específicos da página de Produtos (Catálogo) */
  
  /* Page header */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: auto;
    padding: calc(86px + env(safe-area-inset-top, 0px)) var(--container-px) 1.5rem;
    display: block;
    background: var(--white);
  }
  .hero-visual {
    position: relative;
    width: min(100%, 1180px);
    height: auto;
    min-height: 0;
    margin: 0 auto;
    clip-path: none;
  }
  .hero-visual::after {
    display: none;
  }
  .hero-visual img {
    width: 100%;
    height: auto;
    object-fit: cover;
    object-position: center center;
    border-radius: 28px;
    filter: drop-shadow(2px 4px 8px rgba(0, 0, 0, 0.4));
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    padding: 1rem;
    padding-bottom: 7%;
    pointer-events: none;
  }
  @keyframes fadeInUp {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .hero-title-line {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 2.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--white);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
    margin-bottom: 0.5rem;
  }
  .hero-sub-line {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
  }

  /* Filters */
  .catalog-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    padding: 1rem var(--container-px) 1.5rem;
    background: var(--white);
    position: sticky;
    top: calc(60px + env(safe-area-inset-top, 0px));
    z-index: 50;
    border-bottom: 1px solid rgba(28, 25, 22, 0.06);
  }
  .filter-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--g400);
    width: 100%;
    text-align: center;
    margin-bottom: 0.25rem;
  }
  .filter-select {
    display: none;
    width: min(100%, 320px);
    padding: 0.8rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(28, 25, 22, 0.18);
    background: rgba(255, 255, 255, 0.92);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: #3d3832;
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #3d3832 50%), linear-gradient(135deg, #3d3832 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 4px), calc(100% - 12px) calc(50% - 4px);
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 2.2rem;
  }
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(28, 25, 22, 0.12);
    background: rgba(255, 255, 255, 0.78);
    color: #3d3832;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, background 0.2s, color 0.2s;
  }
  .filter-btn:hover { border-color: rgba(255, 0, 0, 0.35); color: #1c1916; transform: translateY(-1px); }
  .filter-btn.active { background: var(--orange); border-color: var(--orange); color: var(--white); }
  
  @media (max-width: 720px) {
    .catalog-filter { flex-direction: column; align-items: center; }
    .filter-btn { display: none; }
    .filter-select { display: block; }
  }

  /* Product grid */
  .catalog-section {
    background: linear-gradient(180deg, #fbf8f3 0%, #f3eee7 100%);
    width: 100%;
  }
  .catalog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 4rem var(--container-px) 6rem;
    max-width: 1400px;
    margin: 0 auto;
  }
