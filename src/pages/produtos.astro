  <!-- Script de Filtro e Reveal -->
  <script>
    document.addEventListener('astro:page-load', () => {

      // Reveal
      const reveals = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const stagger = Math.min([...(el.parentElement?.querySelectorAll(".reveal") ?? [])].indexOf(el) * 75, 380);
          el.animate([{ opacity: 0, transform: "translateY(22px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 580, delay: stagger, fill: "forwards" as FillMode, easing: "cubic-bezier(0.22,1,0.36,1)" });
          observer.unobserve(el);
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -36px 0px" });
      
      reveals.forEach(el => observer.observe(el));
    });
  </script>

</Layout>

<style>
  /* Estilos específicos da página de Produtos (Catálogo) */
  
  /* Page header */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: auto;
    padding: calc(86px + env(safe-area-inset-top, 0px)) var(--container-px) 1.5rem;
    display: block;
    background: var(--white);
  }
  .hero-visual {
    position: relative;
    width: min(100%, 1180px);
    height: auto;
    min-height: 0;
    margin: 0 auto;
    clip-path: none;
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
  }
  .hero-visual::after {
    display: none;
  }
  .hero-visual img {
    width: 100%;
    height: auto;
    object-fit: cover;
    object-position: center center;
    border-radius: 28px;
    filter: drop-shadow(2px 4px 8px rgba(0, 0, 0, 0.4));
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    padding: 1rem;
    padding-bottom: 7%;
    pointer-events: none;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-title-line {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 2.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--white);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
    margin-bottom: 0.5rem;
    animation: fadeInUp 0.8s ease-out forwards;
  }
  .hero-sub-line {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
    animation: fadeInUp 0.8s ease-out 0.3s forwards;
    opacity: 0;
  }


  /* Product grid */
  .catalog-section {
    background: linear-gradient(180deg, #fbf8f3 0%, #f3eee7 100%);
    width: 100%;
  }
  .catalog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 4rem var(--container-px) 6rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (min-width: 600px) { .catalog-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  @media (min-width: 1024px) { 
    .catalog-grid { 
      grid-template-columns: repeat(3, 1fr); 
      gap: 2.5rem; 
      max-width: 1100px;
      padding: 3rem 2rem 5rem;
    } 
  }

  /* Product card */
  .produto-card {
    background: rgba(255, 255, 255, 0.95);
    padding: 0.75rem;
    position: relative;
    display: flex;
    flex-direction: column;
