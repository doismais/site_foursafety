---
// Hero.astro
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-brand-lines" aria-hidden="true"></div>
  <div class="hero-placeholder" id="hero-slider">
    <img
      src="/images/hero/SLIDER_01.png"
      alt="Profissional com EPI em ambiente industrial"
      data-title="<strong>Somos a 4SAFETY</strong>"
      data-sub="Proteção e Performance e profissional."
      data-link="/produtos"
      class="active"
    />
    <img
      src="/images/hero/SLIDER-02.png"
      alt="Técnico com EPI em área industrial"
      data-title="<strong>Equipamentos para Fumigação com Detecção Segura de Gases</strong>"
      data-sub="Detectores e medidores de gases para monitoramento, controle e segurança em operações de fumigação industrial."
      data-link="/produtos?filter=fumigacao"
    />
    <img
      src="/images/hero/SLIDER_03.png"
      alt="Profissional com respirador e capacete"
      data-title="<strong>Equipamentos para riscos operacionais reais</strong>"
      data-sub="Catálogo técnico com documentação confirmada conforme aplicação."
      data-link="/produtos"
    />
    <img
      src="/images/hero/TUBOS_COLORI.png"
      alt="Distribuidor autorizado UNIPHOS & Tubos KwikDraw"
      data-title="Distribuidor autorizado <strong>UNIPHOS & Tubos KwikDraw</strong>"
      data-sub="Medição pontual, prática e confiável para diferentes gases e vapores."
      data-link="/produtos/deteccao-de-gas/tubo-colorimetrico"
    />
  </div>
  <div class="hero-content">
    <h1 class="hero-h1"><strong>Somos a 4SAFETY</strong></h1>
    <p class="hero-sub">Proteção e Performance e profissional.</p>
    <div class="hero-actions">
      <a href="/produtos" class="btn-primary">Ver produtos</a>
    </div>
  </div>
  <div class="hero-arrows">
    <button
      class="hero-arrow hero-arrow--prev"
      aria-label="Banner anterior"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </button>
    <button class="hero-arrow hero-arrow--next" aria-label="Próximo banner">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 6 15 12 9 18" />
      </svg>
    </button>
  </div>
  <a
    href="#cta-atuacao"
    class="hero-scroll-down"
    aria-label="Role para baixo"
  >
    <div class="scroll-ring"></div>
    <svg
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </a>
</section>

<script>
  function initHero() {
    // ── HERO WAAPI ENTRANCE ──────────────────────────────────────────────
    const heroEls = [
      { el: document.querySelector(".hero-eyebrow"), delay: 200 },
      { el: document.querySelector(".hero-h1"), delay: 420 },
      { el: document.querySelector(".hero-sub"), delay: 640 },
      { el: document.querySelector(".hero-actions"), delay: 860 },
      { el: document.querySelector(".hero-scroll-down"), delay: 1100 },
    ];
    heroEls.forEach(({ el, delay }) => {
      if (!el) return;
      // Garante que o elemento está invisível antes de animar
      (el as HTMLElement).style.opacity = "0";
      const isScrollDown = el.classList.contains("hero-scroll-down");
      el.animate(
        [
          {
            opacity: 0,
            transform: isScrollDown
              ? "translateX(-50%) translateY(28px)"
              : "translateY(28px)",
          },
          {
            opacity: 1,
            transform: isScrollDown
              ? "translateX(-50%) translateY(0)"
              : "translateY(0)",
          },
        ],
        {
          duration: 720,
          delay,
          fill: "forwards",
          easing: "cubic-bezier(0.22,1,0.36,1)",
        },
      );
    });

    // Hero Slider Logic
    const slider = document.getElementById("hero-slider");
    if (slider) {
      const images = slider.querySelectorAll("img");
      const titleEl = document.querySelector(".hero-h1");
      const subEl = document.querySelector(".hero-sub");
      if (images.length && titleEl && subEl) {
        let currentIndex = 0;

        function transitionText(nextImage: HTMLImageElement) {
          const nextTitle = nextImage.dataset.title || "";
          const nextSub = nextImage.dataset.sub || "";
          const nextLink = nextImage.dataset.link || "/produtos";

          const fadeOut: KeyframeAnimationOptions = {
            duration: 220,
            easing: "ease-out",
            fill: "forwards" as FillMode,
          };
          const fadeIn: KeyframeAnimationOptions = {
            duration: 360,
            easing: "cubic-bezier(0.22,1,0.36,1)",
            fill: "forwards" as FillMode,
          };

          const htmlTitleEl = titleEl as HTMLElement;
          const htmlSubEl = subEl as HTMLElement;
          const linkEl = document.querySelector(".hero-actions .btn-primary") as HTMLAnchorElement;

          // Cancela animações anteriores para evitar conflito de opacidade
          htmlTitleEl.getAnimations().forEach((a) => a.cancel());
          htmlSubEl.getAnimations().forEach((a) => a.cancel());
          htmlTitleEl.style.opacity = "1";
          htmlSubEl.style.opacity = "1";

          const titleOut = htmlTitleEl.animate(
            [
              { opacity: 1, transform: "translateY(0)" },
              { opacity: 0, transform: "translateY(10px)" },
            ],
            fadeOut,
          );

          const subOut = htmlSubEl.animate(
            [
              { opacity: 1, transform: "translateY(0)" },
              { opacity: 0, transform: "translateY(10px)" },
            ],
            fadeOut,
          );

          Promise.all([titleOut.finished, subOut.finished]).then(() => {
            htmlTitleEl.innerHTML = nextTitle;
            htmlSubEl.innerHTML = nextSub;
            if (linkEl) linkEl.href = nextLink;

            htmlTitleEl.style.opacity = "0";
            htmlSubEl.style.opacity = "0";

            htmlTitleEl.animate(
              [
                { opacity: 0, transform: "translateY(10px)" },
                { opacity: 1, transform: "translateY(0)" },
              ],
              fadeIn,
            );

            htmlSubEl.animate(
              [
                { opacity: 0, transform: "translateY(10px)" },
                { opacity: 1, transform: "translateY(0)" },
              ],
              fadeIn,
            );
          });
        }

        function setBrandLines(index: number) {
          const brandLines = document.querySelector(".hero-brand-lines") as HTMLElement;
          if (!brandLines) return;
          brandLines.style.transition = "opacity 0.8s ease";
          brandLines.style.opacity = index === 0 ? "0" : "0.8";
        }

        function goTo(index: number) {
          if (index === currentIndex) return;
          images[currentIndex].classList.remove("active");
          currentIndex = index;
          const next = images[currentIndex];
          next.classList.add("active");
          transitionText(next);
          setBrandLines(currentIndex);
          resetAutoplay();
        }

        function nextImage() {
          goTo((currentIndex + 1) % images.length);
        }

        function prevImage() {
          goTo((currentIndex - 1 + images.length) % images.length);
        }

        let autoplayTimer = setInterval(nextImage, 12000);
        function resetAutoplay() {
          clearInterval(autoplayTimer);
          autoplayTimer = setInterval(nextImage, 12000);
        }

        const prevBtn = document.querySelector(".hero-arrow--prev");
        const nextBtn = document.querySelector(".hero-arrow--next");
        if (prevBtn) prevBtn.addEventListener("click", prevImage);
        if (nextBtn) nextBtn.addEventListener("click", nextImage);

        titleEl.innerHTML = images[currentIndex].dataset.title || titleEl.innerHTML;
        subEl.innerHTML = images[currentIndex].dataset.sub || subEl.innerHTML;
        
        const linkEl = document.querySelector(".hero-actions .btn-primary") as HTMLAnchorElement;
        if (linkEl) {
          linkEl.href = images[currentIndex].dataset.link || "/produtos";
        }

        // Estado inicial das brand lines
        setBrandLines(currentIndex);
      }
    }
  }

  document.addEventListener('astro:page-load', initHero);
  // Fallback para garantir init no primeiro carregamento com View Transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
