---
// Nav.astro
---

<nav id="main-nav">
  <a href="/" class="nav-logo">
    <img class="nav-logo-default"
      src="/images/brand/Logo_4Safety-01.webp"
      alt="4Safety"
      />

  </a>

  <!-- Menu Mobile Trigger -->
  <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menu">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="nav-overlay" id="nav-overlay"></div>

  <div class="nav-menu" id="nav-menu">
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/quem-somos">Sobre</a></li>
      <li><a href="/#solucoes">Soluções</a></li>
      <li><a href="/produtos">Produtos</a></li>
      <li><a href="/consulta-de-ca">Consulta CA</a></li>
      <li><a href="/#contato">Contato</a></li>
    </ul>
    <a
      href="https://wa.me/5548999148413"
      class="nav-cta"
      target="_blank"
      rel="noopener noreferrer"
      >Falar com a 4Safety</a
    >
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    // ── NAV SCROLL EFFECT ────────────────────────────────────────────────
    const nav = document.getElementById('main-nav');
    if (nav && !nav.dataset.scrollInit) {
      nav.dataset.scrollInit = 'true';
      const handleScroll = () => {
        if (window.scrollY > 50) {
          nav.classList.add('nav--scrolled');
        } else {
          nav.classList.remove('nav--scrolled');
        }
      };
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();
    }

    // ── MOBILE MENU TOGGLE ───────────────────────────────────────────────
    const navToggle = document.getElementById('nav-toggle');
    const navMenu = document.getElementById('nav-menu');
    const navOverlay = document.getElementById('nav-overlay');
    
    if (navToggle && navMenu && navOverlay && !navToggle.dataset.toggleInit) {
      navToggle.dataset.toggleInit = 'true';

      const closeMenu = () => {
        navToggle.classList.remove('active');
        navMenu.classList.remove('active');
        navOverlay.classList.remove('active');
        document.body.classList.remove('no-scroll');
      };

      navToggle.addEventListener('click', () => {
        const isActive = navToggle.classList.toggle('active');
        navMenu.classList.toggle('active');
        navOverlay.classList.toggle('active');
        document.body.classList.toggle('no-scroll', isActive);
      });

      navOverlay.addEventListener('click', closeMenu);

      // Fecha o menu mobile automaticamente ao clicar em qualquer link
      navMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });
    }
  });
</script>
