---
// Parceiros.astro
---

<!-- PARCEIROS -->
<section class="parceiros" id="parceiros">
  <div class="parceiros-showcase reveal">
    <div class="parceiros-content">
      <h2 class="parceiros-title">
        Segurança, qualidade e confiabilidade.
      </h2>
      <p class="parceiros-sub">
        Atuamos em diversas frentes da segurança preventiva e preditiva,
        veja abaixo e saiba mais.
      </p>
      <a href="#produtos" class="btn-primary">Ver produtos</a>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust">
  <p class="trust-label">Distribuidores autorizados</p>
  <div class="trust-marquee-wrap">
    <div class="trust-track">
      <span class="trust-item"
        ><img
          src="/images/parceiros/uniphos.webp"
          alt="Uniphos"
          loading="lazy"
      /></span>
