---
// Produtos.astro
---

<section class="produtos" id="produtos">
  <div class="produtos-header reveal">
    <p class="section-eyebrow">Portfólio técnico</p>
    <h2 class="section-headline">
      Encontre o equipamento certo para a sua operação.
    </h2>
    <p class="section-sub">
      Produtos selecionados com suporte técnico e documentação confirmada
      conforme aplicação.
    </p>
  </div>
  <div class="produtos-grid">
    <div class="produto-card reveal" data-cat="gas">
      <a
        href="/produtos/deteccao-de-gas/tubo-colorimetrico"
        class="produto-card-link"
      >
        <img
          class="produto-img"
          src="/images/products/produto-tubo-colorimetrico-uniphos.jpg"
          alt="Tubo Colorimétrico Uniphos"
        />
        <div class="produto-badges">
          <span class="badge-norma">NR-33 / NR-15</span>
        </div>
        <h3 class="produto-headline">Tubo Colorimétrico Uniphos</h3>
        <p class="produto-body">
          Análise quantitativa de atmosfera — detecção de gases tóxicos e
          explosivos em campo.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Tubo Colorimétrico Uniphos"
        data-product-img="/images/products/produto-tubo-colorimetrico-uniphos.jpg"
        data-product-slug="tubo-colorimetrico"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="gas">
      <a
        href="/produtos/deteccao-de-gas/bomba-deteccao"
        class="produto-card-link"
      >
        <img
          class="produto-img"
          src="/images/products/produto-bomba-deteccao-gas.png"
          alt="Bomba de Detecção de Gás"
        />
        <div class="produto-badges">
          <span class="badge-norma">NR-33</span>
        </div>
        <h3 class="produto-headline">Bomba de Detecção de Gás</h3>
        <p class="produto-body">
          Bombas manuais e automáticas para amostragem com tubos
          colorimétricos em espaços confinados.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Bomba de Detecção de Gás"
        data-product-img="/images/products/produto-bomba-deteccao-gas.png"
        data-product-slug="bomba-deteccao"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="gas">
      <a
        href="/produtos/deteccao-de-gas/detector-portatil"
        class="produto-card-link"
      >
        <img
          class="produto-img"
          src="/images/products/produto-detector-gas-portatil.png"
          alt="Detector de Gás Portátil"
        />
        <div class="produto-badges">
          <span class="badge-norma">NR-33</span>
        </div>
        <h3 class="produto-headline">Detector de Gás Portátil</h3>
        <p class="produto-body">
          Monitoramento contínuo de O₂, CO, H₂S e gases explosivos. Alarme
          sonoro e visual.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Detector de Gás Portátil"
        data-product-img="/images/products/produto-detector-gas-portatil.png"
        data-product-slug="detector-portatil"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="outros">
      <a href="/produtos/fumigacao" class="produto-card-link">
        <img
          class="produto-img"
          src="/images/products/produto-fumigacao.png"
          alt="Equipamentos de Fumigação"
        />
        <div class="produto-badges">
          <span class="badge-norma">MAPA / ANVISA</span>
        </div>
        <h3 class="produto-headline">Equipamentos de Fumigação</h3>
        <p class="produto-body">
          Aplicadores, dosadores e EPIs para fumigação de silos e armazéns
          industriais.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Equipamentos de Fumigação"
        data-product-img="/images/products/produto-fumigacao.png"
        data-product-slug="fumigacao"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="outros">
      <a
        href="/produtos/fumigacao/lona-sob-medida"
        class="produto-card-link"
      >
        <img
          class="produto-img"
          src="/images/products/produto-lona-fumigacao.png"
          alt="Lona de Fumigação Sob Medida"
        />
        <div class="produto-badges">
          <span class="badge-norma">Sob medida</span>
        </div>
        <h3 class="produto-headline">Lona de Fumigação Sob Medida</h3>
        <p class="produto-body">
          Projeto dimensionado por aplicação, medidas e condição
          operacional, com acesso direto à fábrica.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Lona de Fumigação Sob Medida"
        data-product-img="/images/products/produto-lona-fumigacao.png"
        data-product-slug="lona-fumigacao"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="respiratorio">
      <a href="/produtos/respiratorio" class="produto-card-link">
        <img
          class="produto-img"
          src="/images/products/produto-protecao-respiratoria.jpg"
          alt="Proteção Respiratória"
        />
        <div class="produto-badges">
          <span class="badge-norma">NR-6 / NR-9</span>
        </div>
        <h3 class="produto-headline">Proteção Respiratória</h3>
        <p class="produto-body">
          Representamos alguns tipos de máscaras respiratórias. A
          disponibilidade e a indicação da linha ideal são confirmadas sob
          consulta técnica.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Proteção Respiratória"
        data-product-img="/images/products/produto-protecao-respiratoria.jpg"
        data-product-slug="respiratorio"
      >
        Adicionar ao Orçamento
      </button>
    </div>
    <div class="produto-card reveal" data-cat="altura">
      <a href="/produtos/altura" class="produto-card-link">
        <img
          class="produto-img"
          src="/images/products/produto-equipamentos-altura.png"
          alt="Equipamentos para Altura"
        />
        <div class="produto-badges">
          <span class="badge-norma">NR-35</span>
        </div>
        <h3 class="produto-headline">Equipamentos para Altura</h3>
        <p class="produto-body">
          Trava-quedas, cinturões paraquedistas e sistemas de ancoragem
          certificados.
        </p>
      </a>
      <button
        class="produto-cta produto-cta-btn"
        data-cart-add
        data-product-name="Equipamentos para Altura"
        data-product-img="/images/products/produto-equipamentos-altura.png"
        data-product-slug="altura"
      >
        Adicionar ao Orçamento
      </button>
    </div>
  </div>
  <div class="produtos-cta-wrap reveal">
    <a href="/produtos" class="btn-primary btn-produtos-all"
      >Ver todos os produtos</a
    >
  </div>
</section>
